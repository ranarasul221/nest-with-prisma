enum OtpPurpose {
  EMAIL_VERIFY
  FORGOT_PASSWORD
}

model Otp {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  code      String
  purpose   OtpPurpose
  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([userId, purpose])
  @@map("otps")
}
